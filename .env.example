# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Runtime connection (used by the app via Prisma adapter)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Direct connection for Prisma migrations (for Supabase use the direct/non-pooler URL)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─── Auth (better-auth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"

# Public URL of this app (required in production)
BETTER_AUTH_BASE_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AI inference (Modal.com — NVIDIA T4) ────────────────────────────────────
# After running `modal deploy modal/serve.py`, copy the printed URL here.
# Format: https://<workspace>--aicaf-qwen3-serve.modal.run
MODAL_API_URL="https://your-workspace--aicaf-qwen3-serve.modal.run"

# Modal Proxy Auth — create tokens at https://modal.com/settings/proxy-auth-tokens
# Token ID (starts with wk-)
MODAL_KEY=""
# Token Secret (starts with ws-)
MODAL_SECRET=""

# ─── Xendit (payments) ───────────────────────────────────────────────────────
# Get from https://dashboard.xendit.co/settings/developers → API Keys
XENDIT_SECRET_KEY="xnd_development_..."
# Set this in Xendit dashboard → Webhooks → Verification Token
XENDIT_WEBHOOK_TOKEN="your-webhook-token"
# Public URL for Xendit callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp contact (digits only, country code included)
NEXT_PUBLIC_WHATSAPP_NUMBER="6587470061"
